# Copy to .env and adjust (never commit .env)

PORT=3000

# Comma-separated extra origins (merged with localhost + Netlify prod defaults).
# CLIENT_ORIGIN=https://your-preview--app.netlify.app

# Anakin Search API (https://anakin.io/docs/documentation)
# Get a key from https://anakin.io/dashboard (starts with `ak-`).
ANAKIN_API_KEY=
# Optional. Defaults to https://api.anakin.io/v1
ANAKIN_API_BASE_URL=

# Groq (https://console.groq.com/) — required for the discovery pipeline's
# JSON extraction stage. The frontend never sees this key.
GROQ_API_KEY=
# Optional. Any Groq chat model that supports response_format=json_object.
GROQ_MODEL=llama-3.1-8b-instant

# Discovery pipeline tuning (all optional)
# Search backend selection:
#   auto (default) — try Anakin /v1/search first, fall back to scraping a
#                    DuckDuckGo HTML SERP via Anakin URL Scraper if it errors.
#   api            — only use Anakin /v1/search.
#   serp           — only scrape a DuckDuckGo HTML SERP via Anakin URL Scraper
#                    (use this when /v1/search is degraded; still 100% Anakin).
DISCOVERY_SEARCH_MODE=auto
# How many Anakin Search results to fetch per query (3 credits/call).
DISCOVERY_SEARCH_LIMIT=5
# How many of those URLs to scrape with Anakin URL Scraper for full text.
# Set to 0 to skip the scrape stage and feed Groq only with snippets.
DISCOVERY_ARTICLE_SCRAPE_MAX=3
# When true (default), article scrapes request Anakin URL Scraper generateJson
# (structured page extraction on Anakin's side). Groq then prefers compact JSON
# in prompts instead of raw markdown, lowering TPM. Set false for markdown-only.
DISCOVERY_ANAKIN_GENERATE_JSON=true
# Optional Instagram profile enrichment. Off by default — Instagram blocks
# anonymous scrapers and burns extra credits. Set >0 only after testing.
DISCOVERY_PROFILE_SCRAPE_MAX=0
# If true (default), the endpoint requires GROQ_API_KEY. Set to false to fall
# back to the legacy snippet-only mapper when Groq is unavailable.
DISCOVERY_GROQ_REQUIRED=true

# Apify (https://apify.com) — live Instagram profile on the detail page.
# Create a token: Apify console → Settings → Integrations → API token.
# Actor: apify/instagram-profile-scraper (via apify-client).
APIFY_API_TOKEN=
# Optional. Set true to include raw Apify rows in GET responses (debug only).
# APIFY_RETURN_RAW=

# --- API protection (recommended in production) ---
# Optional shared secrets. When set, clients must send the matching header or
# Authorization: Bearer <key>. Leave unset for local dev without extra headers.
# DISCOVERY_API_KEY=
# ENRICHMENT_API_KEY=   # also accepts X-Enrichment-Key; mirror in frontend as VITE_ENRICHMENT_API_KEY

# Rate limits (per client IP, in-memory; defaults shown)
# RATE_LIMIT_WINDOW_MS=60000
# RATE_LIMIT_MAX=120
# DISCOVERY_RATE_LIMIT_WINDOW_MS=60000
# DISCOVERY_RATE_LIMIT_MAX=10
# ENRICHMENT_RATE_LIMIT_WINDOW_MS=60000
# ENRICHMENT_RATE_LIMIT_MAX=15

# Apify result cache (seconds) — avoids duplicate actor runs for the same username
# ENRICHMENT_CACHE_TTL_SECONDS=300
# ENRICHMENT_CACHE_MISS_TTL_SECONDS=60

# Behind Render/Netlify proxy (default 1 hop)
# TRUST_PROXY_HOPS=1
